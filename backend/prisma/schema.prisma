// Prisma schema — switching databases requires only two changes:
//   1. Change `provider` below (postgresql | mysql | sqlite | sqlserver | mongodb)
//   2. Update DATABASE_URL in your .env file
//
// Run `npm run db:migrate` after any schema change.
//
// To switch databases:
//   Local dev  → provider = "sqlite",     DATABASE_URL="file:./dev.db"
//   Production → provider = "postgresql", DATABASE_URL="postgresql://..."

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  WRITER
  READER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  displayName     String
  role            Role             @default(READER)
  posts           Post[]
  webtoonSeries   WebtoonSeries[]
  webtoonEpisodes WebtoonEpisode[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("users")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  tags        String    @default("[]")
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("posts")
}

model WebtoonSeries {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String           @default("")
  episodes    WebtoonEpisode[]
  authorId    String
  author      User             @relation(fields: [authorId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("webtoon_series")
}

model WebtoonEpisode {
  id         String        @id @default(cuid())
  title      String
  episodeNum Int
  seriesId   String
  series     WebtoonSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  pages      WebtoonPage[]
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([seriesId, episodeNum])
  @@map("webtoon_episodes")
}

model WebtoonPage {
  id        String         @id @default(cuid())
  episodeId String
  episode   WebtoonEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  order     Int
  imageData String
  createdAt DateTime       @default(now())

  @@map("webtoon_pages")
}
