// Prisma schema — switching databases requires only two changes:
//   1. Change `provider` below (postgresql | mysql | sqlite | sqlserver | mongodb)
//   2. Update DATABASE_URL in your .env file
//
// Run `npm run db:migrate` after any schema change.
//
// To switch databases:
//   Local dev  → provider = "sqlite",     DATABASE_URL="file:./dev.db"
//   Production → provider = "postgresql", DATABASE_URL="postgresql://..."

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  WRITER
  READER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         Role     @default(READER)
  posts        Post[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  tags        String    @default("[]")
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("posts")
}
