{
  "version": 2,
  "buildCommand": "npm install && cd backend && npx prisma generate && cd ../frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10,
      "includeFiles": "backend/node_modules/.prisma/**"
    }
  }
}
